generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String           @id @default(nanoid())
  email                     String           @unique
  name                      String
  password                  String?
  emailVerified             Boolean          @default(false)
  image                     String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  avatarUrl                 String?
  emailRemindersEnabled     Boolean          @default(true)
  googleId                  String?          @unique
  inAppNotificationsEnabled Boolean          @default(true)
  timezone                  String           @default("UTC")
  jobApplications           JobApplication[]
  notifications             Notification[]
  resumes                   Resume[]
  accounts                  Account[]
  sessions                  Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model JobApplication {
  id                   String                @id @default(nanoid())
  userId               String
  company              String
  jobTitle             String
  applicationStatus    applicationStatusType @default(SAVED)
  jobURL               String?
  location             String?
  salaryMin            Int?
  salaryMax            Int?
  appliedDate          DateTime?
  notes                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  followUpDate         DateTime?
  followUpNote         String?
  source               String?
  applicationResumes ApplicationResume[] @relation("ApplicationResumesRelation")
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications        Notification[]
  reminderJobs         ReminderJob[]
  contacts             Contact[]
  interviewRounds      InterviewRound[]
  statusHistory        StatusHistory[]

@@index([userId])
  @@index([followUpDate])
}

model Resume {
  id        String   @id @default(nanoid())
  userId    String
  name      String   @db.VarChar(200)
  type      resumeType @default(RESUME)
  slug      String   @unique @default(nanoid())
  content   Json
  settings  Json
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications ApplicationResume[]

  @@index([userId])
  @@index([userId, type])
}

model ApplicationResume {
  id             String        @id @default(nanoid())
  applicationId  String
  resumeId       String
  createdAt      DateTime      @default(now())
  application    JobApplication @relation("ApplicationResumesRelation", fields: [applicationId], references: [id], onDelete: Cascade)
  resume         Resume        @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([applicationId, resumeId])
  @@index([applicationId])
  @@index([resumeId])
}

model Notification {
  id            String           @id @default(nanoid())
  userId        String
  applicationId String?
  type          notificationType
  title         String           @db.VarChar(255)
  body          String?
  readAt        DateTime?
  actionedAt    DateTime?
  createdAt     DateTime         @default(now())
  application   JobApplication?  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([applicationId])
}

model ReminderJob {
  id            String         @id @default(nanoid())
  applicationId String
  scheduledDate DateTime       @db.Date
  sentAt        DateTime?
  createdAt     DateTime       @default(now())
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, scheduledDate])
  @@index([applicationId])
}

model StatusHistory {
  id            String                 @id @default(nanoid())
  applicationId String
  fromStatus    applicationStatusType?
  toStatus      applicationStatusType
  note          String?
  changedAt     DateTime               @default(now())
  application   JobApplication         @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("status_history")
}

model Contact {
  id            String         @id @default(nanoid())
  applicationId String
  name          String         @db.VarChar(200)
  title         String?        @db.VarChar(200)
  email         String?        @db.VarChar(255)
  phone         String?        @db.VarChar(50)
  linkedinUrl   String?
  createdAt     DateTime       @default(now())
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("contact")
}

model InterviewRound {
  id              String             @id @default(nanoid())
  applicationId   String
  roundType       interviewRoundType
  scheduledAt     DateTime?
  interviewerName String?            @db.VarChar(200)
  notes           String?
  outcome         interviewOutcome?
  createdAt       DateTime           @default(now())
  application     JobApplication     @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("interview_round")
}

enum locationType {
  remote
  hybrid
  onsite
}

enum applicationStatusType {
  SAVED
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  CLOSED
}

enum jobType {
  fulltime
  parttime
  internship
}

enum priorityType {
  low
  medium
  high
}

enum roundType {
  phoneScreening
  hrInterview
  technical
  panelInterview
  finalRound
}

enum interviewType {
  online
  offline
}

enum resultType {
  pending
  passed
  failed
}

enum resumeType {
  RESUME
  COVER_LETTER
}

enum notificationType {
  FOLLOW_UP_DUE
  FOLLOW_UP_OVERDUE
}

enum interviewRoundType {
  PHONE_SCREEN
  TECHNICAL
  SYSTEM_DESIGN
  BEHAVIORAL
  FINAL
  OTHER
}

enum interviewOutcome {
  POSITIVE
  NEUTRAL
  NEGATIVE
}
