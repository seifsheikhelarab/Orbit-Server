generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String           @id @default(nanoid())
  email                     String           @unique
  name                      String
  password                  String?
  emailVerified             Boolean          @default(false)
  image                     String?
  googleId                  String?          @unique
  avatarUrl                 String?
  timezone                  String           @default("UTC")
  emailRemindersEnabled     Boolean          @default(true)
  inAppNotificationsEnabled Boolean          @default(true)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  sessions                  Session[]
  accounts                  Account[]
  jobApplications           JobApplication[]
  documents                 Document[]
  notifications             Notification[]
  resumes                   Resume[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum locationType {
  remote
  hybrid
  onsite
}

enum applicationStatusType {
  SAVED
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  CLOSED
}

enum jobType {
  fulltime
  parttime
  internship
}

enum priorityType {
  low
  medium
  high
}

enum roundType {
  phoneScreening
  hrInterview
  technical
  panelInterview
  finalRound
}

enum interviewType {
  online
  offline
}

enum resultType {
  pending
  passed
  failed
}

enum fileType {
  CV
  coverLetter
  portfolio
}

model JobApplication {
  id                String                @id @default(nanoid())
  userId            String
  company           String
  jobTitle          String
  applicationStatus applicationStatusType @default(SAVED)
  jobURL            String?
  location          String?
  salaryMin         Int?
  salaryMax         Int?
  appliedDate       DateTime?
  notes             String?
  followUpDate      DateTime?
  followUpNote      String?
  source            String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationDocuments ApplicationDocument[] @relation("ApplicationDocumentsRelation")
  notifications      Notification[]
  reminderJobs      ReminderJob[]
  statusHistory      StatusHistory[]
  contacts           Contact[]
  interviewRounds    InterviewRound[]

  @@index([userId])
  @@index([followUpDate])
}

enum documentType {
  CV
  COVER_LETTER
  OTHER
}

model Document {
  id              String    @id @default(nanoid())
  userId          String
  name            String    @db.VarChar(200)
  type            documentType
  activeVersionId String?   @unique
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions        DocumentVersion[] @relation("DocumentVersions")

  @@index([userId])
  @@index([deletedAt])
}

model DocumentVersion {
  id                String   @id @default(nanoid())
  documentId        String
  versionNumber     Int
  originalFilename  String   @db.VarChar(255)
  storageKey       String   @db.Text
  mimeType          String   @db.VarChar(100)
  fileSizeBytes     Int
  source            String   @default("LOCAL")
  createdAt         DateTime @default(now())

  document              Document              @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  applicationDocuments   ApplicationDocument[] @relation("VersionApplications")

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

model ApplicationDocument {
  id                  String   @id @default(nanoid())
  applicationId       String
  documentVersionId   String
  createdAt           DateTime @default(now())

  application    JobApplication  @relation("ApplicationDocumentsRelation", fields: [applicationId], references: [id], onDelete: Cascade)
  documentVersion DocumentVersion @relation("VersionApplications", fields: [documentVersionId], references: [id], onDelete: Cascade)

  @@unique([applicationId, documentVersionId])
  @@index([applicationId])
}

model Resume {
  id          String   @id @default(nanoid())
  userId      String
  name        String   @db.VarChar(200)
  slug        String   @unique @default(nanoid())
  content     Json     // Structured resume data
  settings    Json     // Template, colors, fonts, margins
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}


enum notificationType {
  FOLLOW_UP_DUE
  FOLLOW_UP_OVERDUE
}

model Notification {
  id             String            @id @default(nanoid())
  userId         String
  applicationId String?
  type           notificationType
  title          String            @db.VarChar(255)
  body           String?
  readAt         DateTime?
  actionedAt     DateTime?
  createdAt      DateTime          @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  application  JobApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([applicationId])
}

model ReminderJob {
  id             String      @id @default(nanoid())
  applicationId  String
  scheduledDate DateTime    @db.Date
  sentAt         DateTime?
  createdAt      DateTime    @default(now())

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, scheduledDate])
  @@index([applicationId])
}

model StatusHistory {
  id            String                @id @default(nanoid())
  applicationId String
  fromStatus    applicationStatusType?
  toStatus      applicationStatusType
  note          String?
  changedAt     DateTime              @default(now())

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("status_history")
}

model Contact {
  id            String   @id @default(nanoid())
  applicationId String
  name          String   @db.VarChar(200)
  title         String?  @db.VarChar(200)
  email         String?  @db.VarChar(255)
  phone         String?  @db.VarChar(50)
  linkedinUrl   String?  @db.Text
  createdAt     DateTime @default(now())

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("contact")
}

enum interviewRoundType {
  PHONE_SCREEN
  TECHNICAL
  SYSTEM_DESIGN
  BEHAVIORAL
  FINAL
  OTHER
}

enum interviewOutcome {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model InterviewRound {
  id             String            @id @default(nanoid())
  applicationId  String
  roundType      interviewRoundType
  scheduledAt    DateTime?
  interviewerName String?           @db.VarChar(200)
  notes          String?
  outcome        interviewOutcome?
  createdAt      DateTime          @default(now())

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("interview_round")
}
